{
  "builds": [
    {
      "use": "@vercel/static",
      "src": "frontend/dist/**"
    },
    {
      "use": "@vercel/node",
      "src": "backend/src/index.js"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
